# Bavapp backend miljøvariabler
# Kopier til .env og fyll inn. .env er gitignored.

# Port (Railway setter denne automatisk)
PORT=3001

# SQLite database og uploads
DB_PATH=./data/bavaria32.db
UPLOADS_PATH=./uploads

# Signal K server på båtens nettverk (ikke tilgjengelig fra internett)
SIGNALK_URL=http://localhost:3000

# Passord-gate for ikke-lokal tilgang. Ikke satt → ingen gate.
# Localhost og private IP-ranges (192.168.x, 10.x, 172.16-31.x) slipper gjennom uansett.
SITE_USER=bavapp
SITE_PASSWORD=

# Teltonika RUT200 (sett når ruteren er koblet til)
ROUTER_IP=192.168.1.1
ROUTER_USER=admin
ROUTER_PASS=
ROUTER_TLS=0

# Home-port fallback for bunkring-scraping
FALLBACK_LAT=58.1467
FALLBACK_LON=7.9956
SCRAPE_RADIUS_KM=50

# Admin backup/restore — sett til 1 midlertidig ved migrering, deaktiver etter
ENABLE_ADMIN_RESTORE=

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:tom.erik.thorsen@gmail.com
